<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#ECEAEA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="26dp"
        android:paddingTop="18dp"
        android:paddingEnd="26dp"
        android:paddingBottom="18dp">


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="serif"
            android:text="@string/filter_keyword_label"
            android:textColor="#3E86AD"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/filterKeywordInputLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:boxBackgroundColor="#ECEAEA"
            app:boxStrokeColor="#222222"
            app:boxStrokeWidth="1dp"
            app:boxStrokeWidthFocused="1dp"
            app:endIconMode="none"
            app:hintEnabled="false">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/filterKeywordInput"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@android:color/transparent"
                android:fontFamily="serif"
                android:gravity="bottom|start"
                android:hint="@string/filter_keyword_hint"
                android:imeOptions="actionDone"
                android:inputType="textCapWords"
                android:paddingStart="8dp"
                android:paddingTop="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="6dp"
                android:textColor="#111111"
                android:textColorHint="#3E86AD"
                android:textSize="14sp" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filterKeywordChipGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/filterDateFromButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginStart="26dp"
            android:layout_marginTop="34dp"
            android:layout_marginEnd="26dp"
            android:background="@drawable/rounded_button_blue"
            android:fontFamily="serif"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/filter_event_date_from_button"
            android:textAllCaps="false"
            android:textColor="#F4F1F1"
            android:textSize="24sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <TextView
            android:id="@+id/filterDateFromValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="26dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="26dp"
            android:fontFamily="serif"
            android:text="@string/filter_any_date"
            android:textColor="#3E86AD"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/filterDateToButton"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginStart="26dp"
            android:layout_marginTop="6dp"
            android:layout_marginEnd="26dp"
            android:background="@drawable/rounded_button_blue"
            android:fontFamily="serif"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/filter_event_date_to_button"
            android:textAllCaps="false"
            android:textColor="#F4F1F1"
            android:textSize="24sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <TextView
            android:id="@+id/filterDateToValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="26dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="26dp"
            android:fontFamily="serif"
            android:text="@string/filter_any_date"
            android:textColor="#3E86AD"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="42dp"
            android:fontFamily="serif"
            android:text="entrant range:"
            android:textColor="#3E86AD"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_horizontal"
            android:orientation="horizontal">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/filterMinParticipantsInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="24dp"
                android:layout_weight="1"
                app:boxBackgroundColor="#ECEAEA"
                app:boxStrokeColor="#222222"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/filterMinParticipantsInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="serif"
                    android:gravity="bottom|start"
                    android:hint="@string/filter_min_participants_hint"
                    android:inputType="number"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="6dp"
                    android:textColor="#111111"
                    android:textColorHint="#3E86AD"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/filterMaxParticipantsInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_weight="1"
                app:boxBackgroundColor="#ECEAEA"
                app:boxStrokeColor="#222222"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/filterMaxParticipantsInput"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:background="@android:color/transparent"
                    android:fontFamily="serif"
                    android:gravity="bottom|start"
                    android:hint="@string/filter_max_participants_hint"
                    android:inputType="number"
                    android:paddingStart="8dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="6dp"
                    android:textColor="#111111"
                    android:textColorHint="#3E86AD"
                    android:textSize="14sp" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>