<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4C4C4"
    tools:context=".MessageActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/messageHeaderGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.15" />

    <LinearLayout
        android:id="@+id/messageTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#A993D3"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="14dp"
        android:paddingEnd="22dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/messageHeaderGuide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/messageBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="serif"
            android:padding="4dp"
            android:text="@string/back"
            android:textColor="#F4F1F1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/messageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:textColor="#F4F1F1"
            android:textSize="26sp"
            android:textStyle="bold"
            tools:text="Organizer Name" />
    </LinearLayout>

    <TextView
        android:id="@+id/messageEmptyState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/messages_empty_thread"
        android:textColor="#666666"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/messageHeaderGuide"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="gone" />

    <ListView
        android:id="@+id/messageListView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#C4C4C4"
        android:divider="@android:color/transparent"
        android:dividerHeight="8dp"
        android:listSelector="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/messageHeaderGuide"
        app:layout_constraintBottom_toTopOf="@id/messageComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/messageComposer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#C4C4C4"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <EditText
            android:id="@+id/messageInput"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/input_box_outline"
            android:gravity="top|start"
            android:hint="@string/messages_input_hint"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:padding="14dp"
            android:textColor="#111111"
            android:textSize="16sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/messageSendButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rounded_button_blue"
            android:fontFamily="serif"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/messages_send_button"
            android:textAllCaps="false"
            android:textColor="#F4F1F1"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
