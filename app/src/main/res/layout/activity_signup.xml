<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEAEA"
    tools:context=".SignupActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/signupHeaderGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.31" />

    <LinearLayout
        android:id="@+id/signupTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#3E86AD"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/signupHeaderGuide"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/signupTopAppTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/event_lottery_system"
            android:textColor="#F4F1F1"
            android:textSize="28sp"
            android:textStyle="bold" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="70dp">

            <TextView
                android:id="@+id/createBackButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="serif"
                android:padding="4dp"
                android:text="@string/back"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/signupTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/create_an_account"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/signupHeaderGuide">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="42dp"
            android:paddingTop="20dp"
            android:paddingEnd="42dp"
            android:paddingBottom="42dp">

            <ProgressBar
                android:id="@+id/loadingIndicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/name"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createNameInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="textPersonName"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/email"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createEmailInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="textEmailAddress"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/username"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createUsernameInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="textNoSuggestions"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/phone_number_optional"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createPhoneInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="phone"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/password"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="14dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/confirm_password"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createConfirmPasswordInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="6dp"
                android:layout_marginBottom="32dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="textPassword"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/createAccountButton"
                android:layout_width="292dp"
                android:layout_height="88dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/square_button_blue"
                android:fontFamily="serif"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/create_an_account"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="18sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
