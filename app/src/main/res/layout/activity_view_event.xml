<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4C4C4"
    tools:context=".ViewEventActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/viewEventHeaderGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.21" />

    <LinearLayout
        android:id="@+id/viewEventTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#1E2B63"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="22dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/viewEventHeaderGuide"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/viewEventBackButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="serif"
                android:padding="4dp"
                android:text="@string/back"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/createQRCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="serif"
                android:padding="4dp"
                android:text="@string/create_qr_code"
                android:textColor="#F4F1F1"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/viewEventHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="public Event"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/viewEventBackButton" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/viewEventScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#C4C4C4"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/viewEventHeaderGuide">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#C4C4C4"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="0dp"
            android:paddingEnd="18dp"
            android:paddingBottom="24dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="#A7A4A6">

                <ImageView
                    android:id="@+id/viewEventPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/event_poster"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    tools:src="@android:drawable/ic_menu_gallery"
                    tools:visibility="visible" />
            </FrameLayout>

            <TextView
                android:id="@+id/viewEventScreenTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                tools:visibility="gone" />

            <TextView
                android:id="@+id/viewEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="serif"
                android:textColor="#24356B"
                android:textSize="24sp"
                android:textStyle="bold"
                tools:text="EVENT TITLE on DATE" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/viewEventKeywords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                tools:visibility="gone" />

            <TextView
                android:id="@+id/viewEventHost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="serif"
                android:textColor="#111111"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="hosted by: organizer" />

            <TextView
                android:id="@+id/viewEventLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="serif"
                android:textColor="#111111"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="Location: place" />

            <TextView
                android:id="@+id/viewEventDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="serif"
                android:textColor="#111111"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="Event date: March 20" />

            <TextView
                android:id="@+id/viewEventDeadline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="serif"
                android:textColor="#24356B"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="Registration deadline: March 1" />

            <TextView
                android:id="@+id/viewEventMaxEntrants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="serif"
                android:textColor="#111111"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="Max entrants: 250" />

            <TextView
                android:id="@+id/viewEventGeolocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:fontFamily="serif"
                android:textColor="#111111"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="Geolocation required: Yes" />

            <TextView
                android:id="@+id/viewEventDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="serif"
                android:lineSpacingExtra="4dp"
                android:textColor="#111111"
                android:textSize="19sp"
                android:textStyle="bold"
                tools:text="EVENT DESCRIPTION" />

            <TextView
                android:id="@+id/viewEventWaitlistCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:textColor="#24356B"
                android:textSize="19sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="Currently, 27 people are on the wait list"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/viewEventWaitlistJoinedLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="serif"
                android:text="@string/waitlist_joined_label"
                android:textColor="#111111"
                android:textSize="18sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/viewEventCommentsButton"
                android:layout_width="220dp"
                android:layout_height="58dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:background="@drawable/rounded_button_blue"
                android:fontFamily="serif"
                android:gravity="center"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/comments_title"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <LinearLayout
                android:id="@+id/viewEventTopActionRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/viewEventEntrantsButton"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_teal"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/entrants"
                    android:textAllCaps="false"
                    android:textColor="#F4F1F1"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:backgroundTint="@null"
                    tools:visibility="visible" />

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/viewEventEditButton"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:background="@drawable/rounded_button_navy"
                    android:fontFamily="serif"
                    android:gravity="center"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/edit_event_button"
                    android:textAllCaps="false"
                    android:textColor="#F4F1F1"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:backgroundTint="@null"
                    tools:visibility="visible" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/viewEventMessageOrganizerButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/square_button_lavender"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="@string/message_the_organizer"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/viewEventJoinWaitlistButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/square_button_green"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="@string/join_waitlist"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/viewEventLeaveWaitlistButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/square_button_red"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="@string/leave_waitlist"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/viewEventAcceptInvitationButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/square_button_green"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="Accept Invitation"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/viewEventRejectInvitationButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/square_button_red"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="Reject Invitation"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/viewEventShowMapButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/square_button_orange"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="Show Map"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/viewEventSendPrivateButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/square_button_navy"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:paddingStart="22dp"
                android:paddingEnd="22dp"
                android:text="Send Private Event"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="22sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@null"
                tools:visibility="visible" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>