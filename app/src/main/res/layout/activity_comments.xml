<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4C4C4"
    tools:context=".CommentsActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/commentsHeaderGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.17" />

    <LinearLayout
        android:id="@+id/commentsTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#3E86AD"
        android:orientation="vertical"
        android:paddingStart="14dp"
        android:paddingTop="14dp"
        android:paddingEnd="14dp"
        android:paddingBottom="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/commentsHeaderGuide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/commentsBackButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="true"
            android:focusable="true"
            android:fontFamily="serif"
            android:padding="4dp"
            android:text="@string/back"
            android:textColor="#F4F1F1"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/commentsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/comments_title"
            android:textColor="#F4F1F1"
            android:textSize="34sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/commentsEmptyState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/comments_empty_state"
        android:textColor="#666666"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/commentsHeaderGuide"
        app:layout_constraintBottom_toTopOf="@id/commentsComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="gone" />

    <ListView
        android:id="@+id/commentsListView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#C4C4C4"
        android:divider="@android:color/transparent"
        android:dividerHeight="12dp"
        android:listSelector="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/commentsHeaderGuide"
        app:layout_constraintBottom_toTopOf="@id/commentsComposer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/commentsComposer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#3E86AD"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="10dp"
        android:paddingEnd="18dp"
        android:paddingBottom="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="add a comment:"
            android:textColor="#F4F1F1"
            android:textSize="30sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/commentsInput"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/input_box_outline"
            android:gravity="top|start"
            android:hint="@string/comments_input_hint"
            android:inputType="textMultiLine"
            android:minLines="2"
            android:padding="18dp"
            android:textColor="#111111"
            android:textColorHint="#7A84A8"
            android:textSize="18sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/commentsPostButton"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:layout_gravity="end"
            android:layout_marginTop="10dp"
            android:background="@drawable/rounded_button_navy"
            android:fontFamily="serif"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/comments_post_button"
            android:textAllCaps="false"
            android:textColor="#F4F1F1"
            android:textSize="18sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
