<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEAEA"
    tools:context=".AdminEventDetailsActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/adminEventDetailsHeaderGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.333" />

    <LinearLayout
        android:id="@+id/adminEventDetailsTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#D93A4A"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/adminEventDetailsHeaderGuide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/adminEventDetailsBackButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="serif"
                android:padding="4dp"
                android:text="@string/back"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/adminEventDetailsTopTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/admin_zone"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/adminEventDetailsScreenTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="34dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/view_events"
            android:textColor="#F4F1F1"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminEventDetailsSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="event details"
            android:textColor="#F4F1F1"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/adminEventDetailsBottomSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#C8D1D1"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/adminEventDetailsHeaderGuide"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ScrollView
            android:id="@+id/adminEventDetailsScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="26dp"
                android:paddingTop="22dp"
                android:paddingEnd="26dp"
                android:paddingBottom="22dp">

                <TextView
                    android:id="@+id/adminEventDetailsTitleValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    tools:text="Sample Event Title" />

                <ImageView
                    android:id="@+id/adminEventPoster"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginTop="16dp"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    tools:visibility="visible" />

                <TextView
                    android:id="@+id/adminEventHost"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Host: Jane Smith" />

                <TextView
                    android:id="@+id/adminEventLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Location: Edmonton" />

                <TextView
                    android:id="@+id/adminEventDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Date: April 15, 2026" />

                <TextView
                    android:id="@+id/adminEventDeadline"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Deadline: April 10, 2026" />

                <TextView
                    android:id="@+id/adminEventMaxEntrants"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Max entrants: 100" />

                <TextView
                    android:id="@+id/adminEventWaitlistCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Waitlist count: 15" />

                <TextView
                    android:id="@+id/adminEventGeolocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Geolocation required: Yes" />

                <TextView
                    android:id="@+id/adminEventDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="serif"
                    android:textColor="#111111"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    tools:text="Description: Event details go here." />
            </LinearLayout>
        </ScrollView>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/adminDeleteEventButton"
            android:layout_width="match_parent"
            android:layout_height="84dp"
            android:background="@drawable/square_button_red"
            android:fontFamily="serif"
            android:gravity="start|center_vertical"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingStart="22dp"
            android:text="@string/admin_delete_event_confirm_action"
            android:textAllCaps="false"
            android:textColor="#F4F1F1"
            android:textSize="22sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>