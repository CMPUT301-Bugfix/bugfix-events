<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C9D0D0"
    tools:context=".AdminZoneActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top red header area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="243dp"
            android:background="#D93A4A"
            android:orientation="vertical"
            android:paddingStart="28dp"
            android:paddingTop="36dp"
            android:paddingEnd="28dp"
            android:paddingBottom="24dp">

            <!-- top row -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/adminZoneBackButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="serif"
                    android:padding="4dp"
                    android:text="@string/back"
                    android:textColor="#FFF8F0"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/adminZoneTopTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="serif"
                    android:text="my things"
                    android:textColor="#FFF8F0"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/adminZoneTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="72dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/admin_zone"
                android:textColor="#FFF8F0"
                android:textSize="46sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Description area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="155dp"
            android:background="#C9D0D0"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/adminZoneSubtitleLine1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="you can moderate users and"
                android:textColor="#111111"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/adminZoneSubtitleLine2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:fontFamily="serif"
                android:text="content here."
                android:textColor="#111111"
                android:textSize="21sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Buttons area -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminEventsButton"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:background="@drawable/square_button_light"
                android:text="@string/view_events"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:paddingStart="38dp"
                android:paddingEnd="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminUserProfilesButton"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:background="@drawable/square_button_light"
                android:text="@string/view_user_profiles"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:paddingStart="38dp"
                android:paddingEnd="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@null" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/adminPhotosButton"
                android:layout_width="match_parent"
                android:layout_height="84dp"
                android:background="@drawable/square_button_light"
                android:text="@string/admin_photos"
                android:textAllCaps="false"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="start|center_vertical"
                android:paddingStart="38dp"
                android:paddingEnd="24dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:backgroundTint="@null" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/adminRoleLoading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>