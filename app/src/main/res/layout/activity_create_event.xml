<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#C4C4C4"
    tools:context=".CreateEventActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/createEventHeaderGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.12" />

    <LinearLayout
        android:id="@+id/createEventTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#74B3A8"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="22dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/createEventHeaderGuide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/createEventBackButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="serif"
                android:padding="4dp"
                android:text="@string/back"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/createEventHeaderTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/create_event_title"
                android:textColor="#F4F1F1"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/createEventScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#C4C4C4"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/createEventHeaderGuide"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#C4C4C4"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/createEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/create_event_title"
                android:textColor="#24356B"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/createEventSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:text="@string/create_event_subtitle"
                android:textColor="#24356B"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="serif"
                android:text="@string/event_poster"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="10dp"
                android:background="#A7A4A6">

                <ImageView
                    android:id="@+id/createEventPosterPreview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="@string/event_poster"
                    android:scaleType="centerCrop"
                    tools:src="@android:drawable/ic_menu_gallery" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="serif"
                    android:text="add a photo"
                    android:textColor="#F4F1F1"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/createEventPosterButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/square_button_lavender"
                android:fontFamily="serif"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/choose_poster"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <TextView
                android:id="@+id/createEventPosterStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:textColor="#555555"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="serif"
                android:text="@string/event_title_hint"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createEventTitleInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="textCapSentences"
                android:maxLines="1"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:text="@string/event_description_hint"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createEventDescriptionInput"
                android:layout_width="match_parent"
                android:layout_height="140dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_box_outline"
                android:gravity="top|start"
                android:hint=""
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="4"
                android:padding="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:text="@string/event_location_hint"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createEventLocationInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="textCapWords"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/createEventKeywordsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:text="@string/event_keywords_label"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/createEventKeywordInputLayout"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="#C4C4C4"
                app:boxStrokeColor="#4A4A4A"
                app:boxStrokeWidth="1dp"
                app:boxStrokeWidthFocused="1dp"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/createEventKeywordInput"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@android:color/transparent"
                    android:hint="@string/event_keywords_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textCapWords"
                    android:maxLines="1"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textColor="#111111"
                    android:textColorHint="#666666"
                    android:textSize="18sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/createEventAddKeywordButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/square_button_lavender"
                android:fontFamily="serif"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/event_keywords_add"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/createEventKeywordsChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:text="@string/max_entrants_hint"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createEventMaxEntrantsInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:text="@string/max_participants"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createEventMaxParticipantsInput"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_box_outline"
                android:gravity="center_vertical"
                android:hint=""
                android:inputType="number"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:text="Winning Notification Message"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/createEventWinningMessageInput"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/input_box_outline"
                android:gravity="top|start"
                android:hint=""
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="3"
                android:padding="14dp"
                android:textColor="#111111"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/createEventDeadlineLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:text="@string/registration_deadline"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/createEventDeadlineButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/square_button_lavender"
                android:fontFamily="serif"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/pick_date"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <TextView
                android:id="@+id/createEventDeadlineValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:textColor="#555555"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/createEventDateLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:fontFamily="serif"
                android:text="@string/event_date"
                android:textColor="#111111"
                android:textSize="22sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/createEventDateButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/square_button_lavender"
                android:fontFamily="serif"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/pick_date"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

            <TextView
                android:id="@+id/createEventDateValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:textColor="#555555"
                android:textSize="15sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="serif"
                    android:text="@string/requires_geolocation"
                    android:textColor="#111111"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/createEventGeolocationSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:showText="false"
                    app:switchMinWidth="92dp"
                    app:thumbTint="#6AA226"
                    app:trackTint="#6E6E6E" />
            </LinearLayout>

            <TextView
                android:id="@+id/createEventVisibilityLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:fontFamily="serif"
                android:text="@string/event_visibility_label"
                android:textColor="#111111"
                android:textSize="24sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="serif"
                    android:text="@string/event_visibility_public_toggle"
                    android:textColor="#111111"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/createEventPublicSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:showText="false"
                    app:switchMinWidth="92dp"
                    app:thumbTint="#6AA226"
                    app:trackTint="#6E6E6E" />
            </LinearLayout>

            <TextView
                android:id="@+id/createEventVisibilityStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="serif"
                android:textColor="#555555"
                android:textSize="15sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/createEventSubmitButton"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:layout_marginTop="28dp"
                android:background="@drawable/square_button_green"
                android:fontFamily="serif"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/create_event_submit"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="24sp"
                android:textStyle="bold"
                app:backgroundTint="@null" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>