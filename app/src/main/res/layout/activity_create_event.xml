<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground"
    android:padding="16dp"
    tools:context=".CreateEventActivity">

    <TextView
        android:id="@+id/createEventBackButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        android:focusable="true"
        android:padding="8dp"
        android:text="@string/back"
        android:textColor="?attr/colorPrimary"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/createEventScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/createEventBackButton">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/createEventTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/create_event_title"
                android:textColor="?android:textColorPrimary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/createEventSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/create_event_subtitle"
                android:textColor="?android:textColorSecondary"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/createEventTitleInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/event_title_hint"
                android:inputType="textCapSentences"
                android:maxLines="1" />

            <EditText
                android:id="@+id/createEventDescriptionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="top|start"
                android:hint="@string/event_description_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="4" />

            <EditText
                android:id="@+id/createEventLocationInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/event_location_hint"
                android:inputType="textCapWords" />

            <TextView
                android:id="@+id/createEventPosterLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/event_poster"
                android:textColor="?android:textColorPrimary"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/createEventPosterPreview"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="12dp"
                android:adjustViewBounds="true"
                android:contentDescription="@string/event_poster"
                android:scaleType="centerCrop"
                tools:src="@android:drawable/ic_menu_gallery" />

            <Button
                android:id="@+id/createEventPosterButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/choose_poster" />

            <TextView
                android:id="@+id/createEventPosterStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/createEventMaxEntrantsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/max_entrants_hint"
                android:inputType="number" />

            <EditText
                android:id="@+id/createEventMaxParticipantsInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:hint="@string/max_participants"
                android:inputType="number" />

            <EditText
                android:id="@+id/createEventWinningMessageInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:gravity="top|start"
                android:hint="Winning Notification Message"
                android:inputType="textCapSentences|textMultiLine"
                android:minLines="3" />

            <TextView
                android:id="@+id/createEventDeadlineLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/registration_deadline"
                android:textColor="?android:textColorPrimary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/createEventDeadlineButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/pick_date" />

            <TextView
                android:id="@+id/createEventDeadlineValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/createEventDateLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/event_date"
                android:textColor="?android:textColorPrimary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/createEventDateButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/pick_date" />

            <TextView
                android:id="@+id/createEventDateValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="?android:textColorSecondary"
                android:textSize="14sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/createEventGeolocationSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/requires_geolocation" />

            <Button
                android:id="@+id/createEventSubmitButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/create_event_submit" />
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
