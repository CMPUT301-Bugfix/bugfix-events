<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EDEBEB"
    tools:context=".HomeActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/homeHeaderGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.333" />

    <LinearLayout
        android:id="@+id/homeTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#1E2B63"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="14dp"
        app:layout_constraintBottom_toTopOf="@id/homeHeaderGuide"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/qrCodeScan"
                android:layout_width="122dp"
                android:layout_height="50dp"
                android:background="@drawable/square_button_blue"
                android:fontFamily="serif"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/scan_qr_code"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/myThingsButton"
                android:layout_width="156dp"
                android:layout_height="50dp"
                android:background="@drawable/square_button_blue"
                android:fontFamily="serif"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/my_things"
                android:textAllCaps="false"
                android:textColor="#F4F1F1"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@null"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/homeEventsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/browse_events_title"
            android:textColor="#F4F1F1"
            android:textSize="34sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/homeEventsFilterButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/rounded_button_blue"
            android:fontFamily="serif"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/filter_events"
            android:textAllCaps="false"
            android:textColor="#F4F1F1"
            android:textSize="20sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />
    </LinearLayout>

    <TextView
        android:id="@+id/homeEventsEmptyState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#EDEBEB"
        android:fontFamily="serif"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/no_browse_events"
        android:textColor="#111111"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/homeHeaderGuide"
        tools:visibility="gone" />

    <ListView
        android:id="@+id/homeEventsListView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#EDEBEB"
        android:cacheColorHint="@android:color/transparent"
        android:divider="#4A4A4A"
        android:dividerHeight="1dp"
        android:listSelector="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/homeHeaderGuide" />

</androidx.constraintlayout.widget.ConstraintLayout>