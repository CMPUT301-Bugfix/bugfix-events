<?xml version="1.0" encoding="utf-8"?>
<!-- The following code is from OpenAI, ChatGPT, "UI Fix Assistance", 2026-03-25 -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/hostedEventsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ECEAEA"
    tools:context=".HostedEventsActivity">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/hostedEventsHeaderGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.29" />

    <LinearLayout
        android:id="@+id/hostedEventsTopSection"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#74B3A8"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="22dp"
        android:paddingEnd="22dp"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toTopOf="@id/hostedEventsHeaderGuide"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/hostedEventsBackButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="serif"
                android:padding="4dp"
                android:text="@string/back"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/hostedEventsTopTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/my_things"
                android:textColor="#F4F1F1"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/hostedEventsTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="62dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/hosted_events"
            android:textColor="#F4F1F1"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/hostedEventsSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            tools:visibility="gone" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/createEventButton"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:background="@drawable/square_button_green"
        android:fontFamily="serif"
        android:gravity="start|center_vertical"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:paddingStart="36dp"
        android:text="create a new event"
        android:textAllCaps="false"
        android:textColor="#F4F1F1"
        android:textSize="22sp"
        android:textStyle="bold"
        app:backgroundTint="@null"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hostedEventsHeaderGuide" />

    <TextView
        android:id="@+id/hostedEventsEmptyState"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#ECEAEA"
        android:gravity="center"
        android:padding="24dp"
        android:text="@string/no_hosted_events"
        android:textColor="#777777"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/createEventButton"
        tools:visibility="gone" />

    <ListView
        android:id="@+id/hostedEventsListView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#ECEAEA"
        android:cacheColorHint="@android:color/transparent"
        android:divider="#6A6A6A"
        android:dividerHeight="1dp"
        android:listSelector="@android:color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/createEventButton" />

</androidx.constraintlayout.widget.ConstraintLayout>
